# === DeepSeek AI 配置（必填） ===
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat

# === 在线搜索配置（选填） ===
# SerpAPI - Google 搜索结果，申请：https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# === 微信公众号配置（微信集成必填） ===
# 在公众号后台「设置与开发 → 基本配置 → 服务器配置」中获取
WECHAT_TOKEN=your_wechat_token_here
WECHAT_APP_ID=your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here

# 消息加解密密钥（安全/兼容模式必填，43 位字符，明文模式可留空）
WECHAT_ENCODING_AES_KEY=

# === PostgreSQL 数据库（选填，不配置则使用本地 JSON 文件） ===
# POSTGRES_URL=
# DATABASE_URL=
